// container with most water
// two pointer approach!!
class Solution {
    public int maxArea(int[] height) {
        int n = height.length;
        int maxArea = 0;
        int l = 0;
        int r = n-1;

        while(l<r){
            maxArea = Math.max(maxArea, (r-l) * Math.min(height[l], height[r]));

            if(height[l] < height[r]){
                l++;
            }
            else{
                r--;
            }
        }
        return maxArea; 
    }
}
